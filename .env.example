# Docker Compose Environment Variables Template
# Copy to .env and update with your actual values

# PostgreSQL Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=solarxai_medallion
DB_USER=solarxai
DB_PASSWORD=your_secure_password_here

# pgAdmin Configuration
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@solarxai.com
PGADMIN_PASSWORD=your_secure_pgadmin_password_here

# Application Logging
LOG_LEVEL=INFO

# Kafka Configuration (optional)
KAFKA_BROKERS=broker-1:29092,broker-2:29192,broker-3:29292
